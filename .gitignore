# ============================================================
# .gitignore cho Web_Build
# Lưu ý: Giữ lại build output trong git vì sẽ clone về server để chạy
# ============================================================

# ── Environment secrets (chỉ ignore file .env thật, giữ .env.prod template) ──
.env
.env.local

# ── SSL certificates (tạo trên server, không push lên git) ──
*.pem
*.key
*.crt

# ── OS files ──
Thumbs.db
.DS_Store
desktop.ini

# ── Logs ──
*.log

# ── Python cache (audio service) ──
__pycache__/
*.pyc
*.egg-info/
